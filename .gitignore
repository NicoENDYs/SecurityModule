# Scan reports (ephemeral artifacts — not tracked in git).
# Covers everything the scripts write: per-run run_*/ subdirectories,
# SARIF/JSON/HTML/table reports, and logs.
templates/reports/*

# Keep the directory
!templates/reports/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
