# versions.env — Central source of truth for Docker image versions used by all scripts.
# Source this file at the top of every bash script:
#   source "$SECURITY_ROOT/versions.env"
#
# Update these when new stable releases are available and test before merging.
# Pin to exact tags (never :latest or :stable) to guarantee reproducibility.

TRIVY_VERSION=0.61.0
SEMGREP_VERSION=1.95.0
ZAP_VERSION=2.16.0
BENCH_VERSION=1.6.0
NODE_IMAGE=node:22-alpine
